{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": ".cursor/hooks/process-check.sh", "timeout": 5 }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/gate-first-edit.sh",
        "matcher": "Write",
        "timeout": 5
      },
      {
        "command": ".cursor/hooks/gate-first-edit.sh",
        "matcher": "Delete",
        "timeout": 5
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/mark-test-success.sh",
        "matcher": "Shell",
        "timeout": 5
      }
    ],
    "stop": [
      { "command": ".cursor/hooks/verify-completion.sh", "timeout": 10 }
    ]
  }
}
