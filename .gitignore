# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/

# Electron Forge output
out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# signing (never commit)
cert.pfx
*.pfx

# env files (keep .env.example for documentation)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ruvector local data
*.db
.dossier/

# embedding model cache (Node file cache for ruvector-onnx-embeddings-wasm)
.cache/

# local tool artifacts (Claude Code, macOS)
# Developer PATH snapshots (never commit — machine-specific)
.path
.claude.json
.claude/
.DS_Store

# Electron compiled JS output (source is .ts)
electron/*.js
electron/bin/

# marketing / download site (website/)
website/node_modules
website/dist
website/.local
website/.agents

# Local Skillsmith / Cursor convenience (canonical agent skills: .agents/skills/)
/skills/
/skills-lock.json

# Personal Cursor chat workflow scripts (not part of the shipped product)
/scripts/cursor-process-gate-*.sh

